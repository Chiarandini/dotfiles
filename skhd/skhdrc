# focus window — passthrough to Kitty (so zellij gets these for pane focus)
# The `~` operator means "when focused app matches, don't intercept;
# let the keystroke flow to the app normally."
alt - h [
    "kitty" ~
    *       : yabai -m window --focus west
]
alt - j [
    "kitty" ~
    *       : yabai -m window --focus south
]
alt - k [
    "kitty" ~
    *       : yabai -m window --focus north
]
alt - l [
    "kitty" ~
    *       : yabai -m window --focus east
]

# rotate layout clockwise
alt - r : yabai -m space --rotate 270

# Open Kitty
alt - f2 : open -n -a kitty

# flip along y-axis
alt - y : yabai -m space --mirror y-axis

# flip along x-axis
alt - x : yabai -m space --mirror x-axis

# toggle window float
alt - t : yabai -m window --toggle float --grid 4:4:1:1:2:2
alt - p : yabai -m window --resize bottom_right:25:25 --resize top_left:-25:-25
alt - o : yabai -m window --resize bottom_right:-25:-25 --resize top_left:25:25
alt - u : yabai -m window --grid 4:4:1:1:2:2
ctrl + alt  - s : yabai -m window --toggle sticky

# Create/Delete space on the active display
cmd + alt - t : yabai -m space --create
cmd + alt - d : yabai -m space --destroy

# maximize window
alt - m : yabai -m window --toggle zoom-fullscreen

# balance out tree of windows (resize to occupy same area)
alt - e : yabai -m space --balance

# ### Fast focus spaces ###
cmd - 1 : yabai -m space --focus 1
cmd - 2 : yabai -m space --focus 2
cmd - 3 : yabai -m space --focus 3
cmd - 4 : yabai -m space --focus 4
cmd - 5 : yabai -m space --focus 5
cmd - 6 : yabai -m space --focus 6
cmd - 7 : yabai -m space --focus 7
cmd - 8 : yabai -m space --focus 8
cmd - 9 : yabai -m space --focus 9

cmd + shift -1 : yabai -m window --space 1 --focus
# interferes with screenshot key!!
# cmd + shift -2 : yabai -m window --space 2 --focus
# cmd + shift -3 : yabai -m window --space 3 --focus
# cmd + shift -4 : yabai -m window --space 4 --focus
# cmd + shift -5 : yabai -m window --space 5 --focus
cmd + shift -6 : yabai -m window --space 6 --focus
cmd + shift -7 : yabai -m window --space 7 --focus
cmd + shift -8 : yabai -m window --space 8 --focus
# cmd + shift -9 : yabai -m window --space 9 --focus

# cmd - right : yabai -m space --focus next   # Focus the space on the right
# cmd - left : yabai -m space --focus prev    # Focus the space on the left

cmd + ctrl - 1         : yabai -m display --focus 1
cmd + ctrl - 2         : yabai -m display --focus 2
shift + cmd + ctrl - 1 : yabai -m window --display 1 --focus
shift + cmd + ctrl - 2 : yabai -m window --display 2 --focus

# move window and focus desktop
# shift + cmd - 1 : yabai -m window --space  1 --focus
# shift + cmd - 2 : yabai -m window --space  2 --focus
# shift + cmd - 3 : yabai -m window --space  3 --focus
# NOTE: this is incompatible with screnshots!
# shift + cmd - 4 : yabai -m window --space  4 --focus
# shift + cmd - 5 : yabai -m window --space  5 --focus
# shift + cmd - 6 : yabai -m window --space  6 --focus
# shift + cmd - 7 : yabai -m window --space  7 --focus
# shift + cmd - 8 : yabai -m window --space  8 --focus
# swap windows
shift + alt - j : yabai -m window --swap south
shift + alt - k : yabai -m window --swap north
shift + alt - h : yabai -m window --swap west
shift + alt - l : yabai -m window --swap east

# swap windows and split
ctrl + alt - j : yabai -m window --warp south
ctrl + alt - k : yabai -m window --warp north
ctrl + alt - h : yabai -m window --warp west
ctrl + alt - l : yabai -m window --warp east

# right border (hjkl but for left hand)
rshift - a : yabai -m window --resize right:-20:0
rshift - f : yabai -m window --resize right:20:0
rshift - s : yabai -m window --resize bottom:-20:0
rshift - d : yabai -m window --resize bottom:20:0

# padding
rshift - p : yabai -m space --padding rel:5:5:5:5
rshift - o : yabai -m space --padding rel:-5:-5:-5:-5
rshift - w : yabai -m space --gap rel:5:5:5:5
rshift - q : yabai -m space --gap rel:-5:-5:-5:-5

# reset e = equilibrilize
rshift - e : yabai -m space --balance; yabai -m space --gap abs:5:5:5:5; yabai -m space --padding abs:5:5:5:5

# ----- HomeKit bindings (cmd+ctrl + letter, direct binds) -----
#   h = toggle ceiling   b = toggle bed    d = toggle desk
#   a = all on           o = all off
#   s = scene beatsaber  r = scene reading
cmd + ctrl - h : shortcuts run "Toggle Ceiling Lights"
cmd + ctrl - b : shortcuts run "Toggle Bed Lamp"
cmd + ctrl - d : shortcuts run "Toggle Desk Lamp"
cmd + ctrl - a : shortcuts run "Scene All On"
cmd + ctrl - o : shortcuts run "Scene All Off"
cmd + ctrl - s : shortcuts run "Scene Beatsaber"
cmd + ctrl - r : shortcuts run "Scene Reading"
