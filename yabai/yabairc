#!/usr/bin/env sh

# SCRIPTING ADDITION (SA)
# -----------------------
# yabai's SA requires a sudoers entry with the SHA-256 hash of the yabai binary.
# When yabai is updated (e.g. brew upgrade), the hash changes and the SA breaks.
#
# This is handled automatically:
#   - A brew wrapper in .zshrc detects yabai upgrades and re-runs the fix.
#   - The install.sh bootstrap script runs it on fresh machines.
#   - If it ever breaks manually, just run:  fix-yabai-sa
#
# See: https://github.com/koekeishiya/yabai/wiki/Installing-yabai-(latest-release)#configure-scripting-addition
yabai -m signal --add event=window_destroyed action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus mouse"
yabai -m signal --add event=application_terminated action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus mouse"

# Load scripting addition using absolute paths for background service boot
/usr/bin/sudo /opt/homebrew/bin/yabai --load-sa

# Reload scripting addition automatically if the macOS Dock ever crashes/restarts
/opt/homebrew/bin/yabai -m signal --add event=dock_did_restart action="/usr/bin/sudo /opt/homebrew/bin/yabai --load-sa"


# float settings windows
yabai -m rule --add app='^(Messenger|WhatsApp|Messages|Calculator|Archive Utility|System Settings|Raycast|Fantastical|Finder)$' manage=off

# global settings
yabai -m config                                 \
    mouse_follows_focus          off            \
    focus_follows_mouse          off            \
    window_origin_display        default        \
    window_placement             second_child   \
    window_zoom_persist          on             \
    window_shadow                on             \
    window_animation_duration    0.0            \
    window_animation_frame_rate  120            \
    window_opacity_duration      0.0            \
    active_window_opacity        1.0            \
    normal_window_opacity        0.90           \
    window_opacity               off            \
    insert_feedback_color        0xffd75f5f     \
    split_ratio                  0.50           \
    split_type                   auto           \
    auto_balance                 off            \
    top_padding                  06             \
    bottom_padding               06             \
    left_padding                 06             \
    right_padding                06             \
    window_gap                   06             \
    layout                       bsp            \
    mouse_modifier               fn             \
    mouse_action1                move           \
    mouse_action2                resize         \
    mouse_drop_action            swap

echo "yabai configuration loaded.."
